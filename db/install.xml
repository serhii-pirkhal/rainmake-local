<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/rainmake_backend/db" VERSION="2025063001" COMMENT="Rainmake Backend tables">
    <TABLES>
        <TABLE NAME="local_rainmake_backend_careerpaths" COMMENT="Careerpaths">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="title" TYPE="char" LENGTH="255" NOTNULL="true"/>
                <FIELD NAME="description" TYPE="text" NOTNULL="false"/>
                <FIELD NAME="type" TYPE="char" LENGTH="255" NOTNULL="false"/>
                <FIELD NAME="difficulty" TYPE="char" LENGTH="255" NOTNULL="false"/>
                <FIELD NAME="exp" TYPE="int" LENGTH="10" NOTNULL="false"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
            </KEYS>
        </TABLE>

        <TABLE NAME="local_rainmake_backend_coursemeta" COMMENT="Additional course data">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" UNIQUE="true"/>
                <FIELD NAME="careerpathid" TYPE="int" LENGTH="10" NOTNULL="false"/>
                <FIELD NAME="topic" TYPE="text" NOTNULL="false"/>
                <FIELD NAME="language" TYPE="char" LENGTH="10" NOTNULL="false"/>
                <FIELD NAME="subtitlelanguage" TYPE="char" LENGTH="10" NOTNULL="false"/>
                <FIELD NAME="level" TYPE="char" LENGTH="10" NOTNULL="false"/>
                <FIELD NAME="duration" TYPE="int" LENGTH="10" NOTNULL="false"/>
                <FIELD NAME="description" TYPE="text" NOTNULL="false"/>
                <FIELD NAME="will_teach" TYPE="text" NOTNULL="false"/>
                <FIELD NAME="target" TYPE="text" NOTNULL="false"/>
                <FIELD NAME="welcome" TYPE="text" NOTNULL="false"/>
                <FIELD NAME="congrats" TYPE="text" NOTNULL="false"/>
                <FIELD NAME="requirements" TYPE="text" NOTNULL="false"/>
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
                <KEY NAME="coursefk" TYPE="foreign" FIELDS="courseid" REFTABLE="course" REFFIELDS="id"/>
                <KEY NAME="careerpathfk" TYPE="foreign" FIELDS="careerpathid" REFTABLE="local_rainmake_backend_careerpaths" REFFIELDS="id"/>
            </KEYS>
        </TABLE>

        <TABLE NAME="local_rainmake_backend_sessions" COMMENT="Course sessions">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="title" TYPE="char" LENGTH="255" NOTNULL="true"/>
                <FIELD NAME="sortorder" TYPE="int" LENGTH="10" NOTNULL="false"/>
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
                <KEY NAME="coursefk" TYPE="foreign" FIELDS="courseid" REFTABLE="course" REFFIELDS="id"/>
            </KEYS>
        </TABLE>

        <TABLE NAME="local_rainmake_backend_lectures" COMMENT="Session lectures">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="sessionid" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="title" TYPE="char" LENGTH="255" NOTNULL="true"/>
                <FIELD NAME="type" TYPE="char" LENGTH="50" NOTNULL="true"/>
                <FIELD NAME="description" TYPE="text" NOTNULL="false"/>
                <FIELD NAME="notes" TYPE="text" NOTNULL="false"/>
                <FIELD NAME="sortorder" TYPE="int" LENGTH="10" NOTNULL="false"/>
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
                <KEY NAME="sessionfk" TYPE="foreign" FIELDS="sessionid" REFTABLE="local_rainmake_backend_sessions" REFFIELDS="id"/>
            </KEYS>
        </TABLE>

        <TABLE NAME="local_rainmake_backend_lecture_video" COMMENT="Video content for a lecture">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="lectureid" TYPE="int" LENGTH="10" NOTNULL="true" COMMENT="Reference to lecture"/>
                <FIELD NAME="filename" TYPE="char" LENGTH="255" NOTNULL="false"/>
                <FIELD NAME="duration" TYPE="int" LENGTH="10" NOTNULL="false" COMMENT="Duration in seconds"/>
                <FIELD NAME="thumbnail" TYPE="char" LENGTH="255" NOTNULL="false" COMMENT="URL to thumbnail image"/>
                <FIELD NAME="url" TYPE="char" LENGTH="255" NOTNULL="false" COMMENT="Direct URL to video file"/>
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="false"/>
            </FIELDS>

            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
                <KEY NAME="lecturefk" TYPE="foreign" FIELDS="lectureid" REFTABLE="local_rainmake_backend_lectures" REFFIELDS="id"/>
            </KEYS>

            <INDEXES>
                <INDEX NAME="lectureid_idx" UNIQUE="false" FIELDS="lectureid"/>
            </INDEXES>
        </TABLE>

        <TABLE NAME="local_rainmake_backend_lecture_files" COMMENT="Attached files for a lecture">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="lectureid" TYPE="int" LENGTH="10" NOTNULL="true" COMMENT="Reference to lecture"/>
                <FIELD NAME="filename" TYPE="char" LENGTH="255" NOTNULL="true"/>
                <FIELD NAME="filepath" TYPE="char" LENGTH="255" NOTNULL="true" COMMENT="Full path or Moodle filearea reference"/>
                <FIELD NAME="filesize" TYPE="int" LENGTH="10" NOTNULL="false"/>
                <FIELD NAME="mimetype" TYPE="char" LENGTH="100" NOTNULL="false"/>
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="false"/>
            </FIELDS>

            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
                <KEY NAME="lecturefk" TYPE="foreign" FIELDS="lectureid" REFTABLE="local_rainmake_backend_lectures" REFFIELDS="id"/>
            </KEYS>

            <INDEXES>
                <INDEX NAME="lectureid_idx" UNIQUE="false" FIELDS="lectureid"/>
            </INDEXES>
        </TABLE>

        <TABLE NAME="local_rainmake_backend_lecture_views" COMMENT="Stores lecture views by users">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true" COMMENT="Primary key"/>
                <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" COMMENT="User who viewed the lecture"/>
                <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" COMMENT="Viewed course ID"/>
                <FIELD NAME="sessionid" TYPE="int" LENGTH="10" NOTNULL="true" COMMENT="Viewed session ID"/>
                <FIELD NAME="lectureid" TYPE="int" LENGTH="10" NOTNULL="true" COMMENT="Viewed lecture ID"/>
                <FIELD NAME="viewed_at" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" COMMENT="Timestamp of viewing"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
                <KEY NAME="unique_user_lecture" TYPE="unique" FIELDS="userid,lectureid"/>
                <KEY NAME="fk_user" TYPE="foreign" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>
                <KEY NAME="fk_lecture" TYPE="foreign" FIELDS="lectureid" REFTABLE="local_rainmake_backend_lectures" REFFIELDS="id"/>
                <KEY NAME="fk_course" TYPE="foreign" FIELDS="courseid" REFTABLE="course" REFFIELDS="id"/>
                <KEY NAME="fk_session" TYPE="foreign" FIELDS="sessionid" REFTABLE="local_rainmake_backend_sessions" REFFIELDS="id"/>
            </KEYS>
        </TABLE>

        <TABLE NAME="local_rainmake_backend_user_social" COMMENT="Stores user social">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true" COMMENT="Primary key"/>
                <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" COMMENT="User who viewed the lecture"/>
                <FIELD NAME="website" TYPE="char" LENGTH="255" NOTNULL="false"/>
                <FIELD NAME="facebook" TYPE="char" LENGTH="255" NOTNULL="false"/>
                <FIELD NAME="slack" TYPE="char" LENGTH="255" NOTNULL="false"/>
                <FIELD NAME="linkedin" TYPE="char" LENGTH="255" NOTNULL="false"/>
                <FIELD NAME="instagram" TYPE="char" LENGTH="255" NOTNULL="false"/>
                <FIELD NAME="twitter" TYPE="char" LENGTH="255" NOTNULL="false"/>
                <FIELD NAME="youtube" TYPE="char" LENGTH="255" NOTNULL="false"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
                <KEY NAME="fk_user" TYPE="foreign" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>
            </KEYS>
        </TABLE>

        <TABLE NAME="local_rainmake_backend_user_notification" COMMENT="Stores notifications settings">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true" COMMENT="Primary key"/>
                <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="buy_course" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0"/>
                <FIELD NAME="write_review" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0"/>
                <FIELD NAME="comment_course" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0"/>
                <FIELD NAME="download_notes" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0"/>
                <FIELD NAME="reply_comment" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0"/>
                <FIELD NAME="people_visited" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0"/>
                <FIELD NAME="download_attach" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
                <KEY NAME="fk_user" TYPE="foreign" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>
            </KEYS>
        </TABLE>

        <TABLE NAME="local_rainmake_backend_practices" COMMENT="Course practices">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="name" TYPE="char" LENGTH="255" NOTNULL="true"/>
                <FIELD NAME="sortorder" TYPE="int" LENGTH="10" NOTNULL="false" DEFAULT="0"/>
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="false"/>
                <FIELD NAME="type" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="quiz"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
                <KEY NAME="coursefk" TYPE="foreign" FIELDS="courseid" REFTABLE="course" REFFIELDS="id"/>
            </KEYS>
        </TABLE>

        <TABLE NAME="local_rainmake_backend_practice_questions" COMMENT="Practice questions">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="practice_id" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="question" TYPE="text" NOTNULL="true"/>
                <FIELD NAME="sortorder" TYPE="int" LENGTH="10" NOTNULL="false" DEFAULT="0"/>
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="false"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
                <KEY NAME="practicefk" TYPE="foreign" FIELDS="practice_id" REFTABLE="local_rainmake_backend_practices" REFFIELDS="id"/>
            </KEYS>
        </TABLE>

        <TABLE NAME="local_rainmake_backend_practice_question_options" COMMENT="Practice question options">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="question_id" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="content" TYPE="text" NOTNULL="true"/>
                <FIELD NAME="is_correct" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0"/>
                <FIELD NAME="sortorder" TYPE="int" LENGTH="10" NOTNULL="false" DEFAULT="0"/>
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="false"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
                <KEY NAME="questionfk" TYPE="foreign" FIELDS="question_id" REFTABLE="local_rainmake_backend_practice_questions" REFFIELDS="id"/>
            </KEYS>
        </TABLE>

        <TABLE NAME="local_rainmake_backend_careerpath_courses" COMMENT="Courses linked to career paths">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="careerpath_id" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="course_id" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="false"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
                <KEY NAME="careerpathfk" TYPE="foreign" FIELDS="careerpath_id" REFTABLE="local_rainmake_backend_careerpaths" REFFIELDS="id"/>
                <KEY NAME="coursefk" TYPE="foreign" FIELDS="course_id" REFTABLE="course" REFFIELDS="id"/>
            </KEYS>
        </TABLE>

        <TABLE NAME="local_rainmake_backend_course_types" COMMENT="Course types">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="course_id" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="type" TYPE="text" NOTNULL="true"/>
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="false"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
                <KEY NAME="coursefk" TYPE="foreign" FIELDS="course_id" REFTABLE="course" REFFIELDS="id"/>
            </KEYS>
        </TABLE>

        <TABLE NAME="assignment_tasks_curriculum" COMMENT="Selected curriculum items for assigned tasks">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="task_id" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="item_type" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="course"/>
                <FIELD NAME="course_id" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="module_id" TYPE="int" LENGTH="10" NOTNULL="false" DEFAULT="0"/>
                <FIELD NAME="lecture_id" TYPE="int" LENGTH="10" NOTNULL="false" DEFAULT="0"/>
                <FIELD NAME="title" TYPE="char" LENGTH="255" NOTNULL="true"/>
                <FIELD NAME="subtitle" TYPE="char" LENGTH="255" NOTNULL="false"/>
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
                <KEY NAME="fk_task" TYPE="foreign" FIELDS="task_id" REFTABLE="assignment_tasks" REFFIELDS="id"/>
                <KEY NAME="fk_course" TYPE="foreign" FIELDS="course_id" REFTABLE="course" REFFIELDS="id"/>
            </KEYS>
        </TABLE>

        <TABLE NAME="local_rainmake_backend_practice_answers" COMMENT="Practice answers by users">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="question_id" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="option" TYPE="text" NOTNULL="false"/>
                <FIELD NAME="course_id" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="practice_id" TYPE="int" LENGTH="10" NOTNULL="true"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
                <KEY NAME="userfk" TYPE="foreign" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>
                <KEY NAME="questionfk" TYPE="foreign" FIELDS="question_id" REFTABLE="local_rainmake_backend_practice_questions" REFFIELDS="id"/>
                <KEY NAME="coursefk" TYPE="foreign" FIELDS="course_id" REFTABLE="course" REFFIELDS="id"/>
                <KEY NAME="practicefk" TYPE="foreign" FIELDS="practice_id" REFTABLE="local_rainmake_backend_practices" REFFIELDS="id"/>
            </KEYS>
        </TABLE>

        <TABLE NAME="assignment_tasks" COMMENT="Tasks linked to courses">
            <FIELDS>
                <FIELD NAME="id"         TYPE="int"    LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="name"       TYPE="char"   LENGTH="255" NOTNULL="true"/>
                <FIELD NAME="course_id"  TYPE="int"    LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="feedback"   TYPE="text"                   NOTNULL="false"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
                <KEY NAME="fk_course" TYPE="foreign"
                     FIELDS="course_id" REFTABLE="course" REFFIELDS="id"/>
            </KEYS>
        </TABLE>
        <TABLE NAME="assignment_tasks_courses" COMMENT="Courses linked to tasks (many-to-many)">
            <FIELDS>
                <FIELD NAME="id"      TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="task_id" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="course_id" TYPE="int" LENGTH="10" NOTNULL="true"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
                <KEY NAME="fk_task" TYPE="foreign" FIELDS="task_id" REFTABLE="assignment_tasks" REFFIELDS="id"/>
                <KEY NAME="fk_course" TYPE="foreign" FIELDS="course_id" REFTABLE="course" REFFIELDS="id"/>
            </KEYS>
        </TABLE>
        <TABLE NAME="assignment_tasks_files" COMMENT="File paths for each task">
            <FIELDS>
                <FIELD NAME="id"      TYPE="int"    LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="task_id" TYPE="int"    LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="filepath" TYPE="text"                  NOTNULL="true"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
                <KEY NAME="fk_task" TYPE="foreign"
                     FIELDS="task_id" REFTABLE="assignment_tasks" REFFIELDS="id"/>
            </KEYS>
        </TABLE>
        <TABLE NAME="assignment_tasks_students" COMMENT="Students assigned to tasks">
            <FIELDS>
                <FIELD NAME="id"      TYPE="int"    LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="task_id" TYPE="int"    LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="user_id" TYPE="int"    LENGTH="10" NOTNULL="true"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary"    TYPE="primary" FIELDS="id"/>
                <KEY NAME="fk_task"    TYPE="foreign" FIELDS="task_id"
                     REFTABLE="assignment_tasks" REFFIELDS="id"/>
                <KEY NAME="fk_user"    TYPE="foreign" FIELDS="user_id"
                     REFTABLE="user" REFFIELDS="id"/>
            </KEYS>
        </TABLE>
    </TABLES>
</XMLDB>
